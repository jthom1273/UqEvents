{
    "_comment": "Copy this to config.json. Never commit config.json — it is gitignored.",
    "extractor": {
        "instagram": {
            "cookies": "cookies.txt",
            "metadata": true,
            "download": false,
            "post-range": "1-5",
            "postprocessors": [{
                "name": "metadata",
                "mode": "custom",
                "event": "post",
                "extension": "txt",
                "format": "{description}\n"
            }]
        }
    }
}
